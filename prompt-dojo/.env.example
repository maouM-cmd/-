# Prompt Dojo — environment variables
# Copy to .env.local for development

# Required
AUTH_SECRET=generate-a-random-secret
ADMIN_PASSWORD=change-me-in-production

# App URL (production)
APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=プロンプ道場

# OAuth (optional — enable per provider)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
APPLE_ID=
APPLE_SECRET=
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false
NEXT_PUBLIC_GITHUB_AUTH_ENABLED=false

# LLM (optional — falls back to rule-based scoring)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_DAILY_LIMIT=10
LLM_CHALLENGE_GEN_LIMIT=5

# Web Push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Native FCM (optional — Web Push still works without these)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Email (optional — required for email/password auth)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Ads (optional)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT=

# Legal / contact
NEXT_PUBLIC_OPERATOR_NAME=プロンプ道場運営
NEXT_PUBLIC_CONTACT_EMAIL=contact@example.com
