# 本番公開 URL（プッシュ通知・絶対リンク用）
APP_URL=https://nomikai-ai.onrender.com

# OpenAI（盛り上げ AI 生成 — 未設定時はテンプレートにフォールバック）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic（OpenAI 未設定時に使用）
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Maps / Places（店舗検索 — 未設定時はテンプレートにフォールバック）
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google OAuth（ログイン — 未設定時はメール/パスワードのみ）
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com
