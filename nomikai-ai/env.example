# OpenAI（盛り上げ AI 生成 — 未設定時はテンプレートにフォールバック）
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Google Maps / Places（店舗検索 — 未設定時はテンプレートにフォールバック）
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Web Push（幹事向け参加通知 — 未設定時は無効）
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@example.com
